# sandy.toml — Sandy configuration file
#
# Copy this file to one of these locations:
#   ~/.config/sandy/sandy.toml   (recommended — keeps secrets out of project)
#   ./sandy.toml                 (project root, for local dev)
#
# Conventions:
#   UPPERCASE keys = environment variables (secrets, tokens, API keys)
#   lowercase keys = configuration values  (e.g. active = "yes"/"no")
#
# active = "yes"/"no" controls whether Sandy loads a plugin at all.
# Active is case-insensitive: yes, YES, Yes all work.
# If a plugin has no section here, it is active by default.


# ---- Global environment variables ----
# These apply to all plugins.

# Printer used by the cryptics plugin.
# Option 1 — CUPS queue name (run `lpstat -p` to find yours):
# SANDY_PRINTER = "Brother_MFC_L2750DW_series"
#
# Option 2 — Direct IPP URI (recommended for Linux/homelab; bypasses CUPS
# hostname/mDNS resolution). Find the printer's IP on your router, then:
# SANDY_PRINTER = "ipp://192.168.1.50/ipp/print"
# Most Brother printers expose /ipp/print on port 631 (default IPP port).


# ---- Music Discovery Plugin ----
# Replaces the Spotify new-releases plugin with a Last.fm-powered discovery flow.
# Fetches Tom's top artists from Last.fm, finds similar artists, and populates
# a Spotify playlist with tracks he likely hasn't heard.
[music_discovery]
active = "yes"

LASTFM_API_KEY        = "your-lastfm-api-key-here"
LASTFM_API_SECRET     = "your-lastfm-api-secret-here"
LASTFM_USERNAME       = "your-lastfm-username-here"

SPOTIPY_CLIENT_ID     = "your-client-id-here"
SPOTIPY_CLIENT_SECRET = "your-client-secret-here"
SPOTIPY_REDIRECT_URI  = "http://127.0.0.1:8888/callback"
SPOTIFY_PLAYLIST_ID   = "your-playlist-id-here"


# ---- Spotify Plugin ----
# Disabled in favour of music_discovery above.
[spotify]
active = "no"

SPOTIPY_CLIENT_ID     = "your-client-id-here"
SPOTIPY_CLIENT_SECRET = "your-client-secret-here"
SPOTIPY_REDIRECT_URI  = "http://127.0.0.1:8888/callback"


# ---- Cryptics Plugin ----
[cryptics]
active = "yes"

# Printer override at plugin scope (overrides global SANDY_PRINTER above)
# SANDY_PRINTER = "ipp://192.168.1.50/ipp/print"


# ---- Real Men Plugin ----
[real_men]
active = "yes"


# ---- Hardcover Plugin ----
[hardcover]
active = "yes"

HARDCOVER_API_KEY = "your-hardcover-api-key-here"


# ---- Sports Plugin ----
[sports]
active = "yes"

# Register free at https://www.football-data.org/ to get a key for Premier League (Everton)
FOOTBALL_DATA_API_KEY = "your-key-here"


# ---- Estimated Taxes Plugin ----
# Wraps the `estimatedtaxes` CLI tool (must be on PATH).
# Env vars are injected into os.environ and inherited by the subprocess.
[estimatedtaxes]
active = "yes"

ATEAM_EMAIL    = "your-ateam-email-here"
ATEAM_PASSWORD = "your-ateam-password-here"


# ---- IT Guy Plugin ----
# Wraps the `itguy` CLI tool for homelab deploys (must be on PATH).
# No env vars needed — itguy reads its own config from ~/.config/itguy/itguy.toml.
[itguy]
active = "yes"


# ---- Cast to TV Plugin ----
# Chromecast/Google TV control via pychromecast.
[cast_to_tv]
active = "yes"

# Friendly name of the Chromecast device (run the plugin to see discovered names)
CAST_DEVICE_NAME = "Living Room TV"
# Seconds to wait for device discovery
CAST_TIMEOUT     = "10"


# ---- YouTube TV Plugin ----
# Tunes YouTube TV channels via ADB over the network.
# Requires ADB debugging enabled on the Google TV device.
[youtube_tv]
active = "yes"

# IP address of the Google TV on the LAN (required)
YOUTUBE_TV_ADB_HOST = "192.168.1.xxx"
# ADB port (default: 5555)
# YOUTUBE_TV_ADB_PORT = "5555"
# Path to adb binary (default: "adb" on PATH)
# YOUTUBE_TV_ADB_PATH = "adb"


# ---- Health Plugin ----
# Built-in diagnostic — lists all active plugins and commands. No config needed.
[health]
active = "yes"


# ---- Dispatch Plugin ----
# Read-only window into the Dispatch automation system. No API keys needed.
# Disabled by default — only useful when Sandy runs on the same Mac as the
# metaframework checkout and Obsidian vault. Set active = "yes" to enable.
[dispatch]
active = "no"

# DISPATCH_OBSIDIAN_DIR = "/path/to/notes/Dispatch"
# DISPATCH_METAFRAMEWORK_DIR = "/path/to/metaframework"


# ---- Daemon Configuration ----
# Controls which transports are active when running `sandy serve`
[daemon]
transports = ["slack"]
log_level = "INFO"  # DEBUG, INFO, WARNING, ERROR


# ---- Slack Transport ----
[slack]
# Get these from https://api.slack.com/apps — Socket Mode must be enabled
SLACK_APP_TOKEN = "xapp-..."
SLACK_BOT_TOKEN = "xoxb-..."
